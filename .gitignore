# Ignore .env file containing sensitive information
.env

# Ignore the Laravel /vendor directory
/vendor/

# Ignore the public storage symlink
/public/storage/

# Ignore the storage directory
/storage/

# Ignore cache
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# Ignore node_modules directory
/node_modules/

# Ignore config files
/config/auth.php
/config/database.php
/config/filesystems.php
/config/organization.php

# Git worktrees
.worktrees/

# Ignore IDE files
.idea/
/.vscode/

# Ignore system files
.DS_Store
Thumbs.db

# C# build artifacts
UsbTokenSigningService/bin/
UsbTokenSigningService/obj/
UsbTokenSigningService.Tests/bin/
UsbTokenSigningService.Tests/obj/
*.user
.vs/
